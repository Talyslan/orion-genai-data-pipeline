MINIO_URL=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bronze
MINIO_SECURE=false

# Fonte local para ingestão de arquivos locais
DATA_SOURCE_DIR=./pdfs
DATA_SOURCE_EXTENSIONS=.txt,.md,.pdf

# PDF — ingestão e extração (terceira entrega)
PDF_EXTRACTOR=pymupdf
PDF_EXTRACTION_MODE=structured
PDF_MAX_PAGES=0
PDF_OCR_ENABLED=true
PDF_OCR_MIN_CHARS=50
PDF_OCR_LANG=eng+por
PDF_OCR_DPI=200
PDF_EXTRACT_TABLES=true
PDF_FIGURE_PLACEHOLDER=true
PDF_MANIFEST_PATH=./pdfs/manifest.yaml
PDF_DOWNLOAD_DIR=./pdfs
PDF_DOWNLOAD_SKIP_EXISTING=true
PDF_DOWNLOAD_TIMEOUT_SECONDS=120

# OCR — Tesseract (Windows: bash scripts/setup-tesseract.sh → .venv/share/tesseract)
# Deixe vazio para auto-detecção do binário local no .venv
TESSERACT_CMD=
TESSDATA_PREFIX=

LOCAL_OUTPUT_DIR=data/local
REQUEST_TIMEOUT_SECONDS=30

# Legado — ingestão por URL
SCRAPE_URL=https://example.com

# Transformação
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
CLEANER_STRIP_NAV=true
CLEANER_MAX_BLANK_LINES=2

EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

POSTGRES_URL=postgresql://orion:orion@localhost:5433/orion
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=document_embeddings

# API HTTP
PIPELINE_API_URL=http://localhost:8000/api
SITE_MANIFEST_PATH=./sites/manifest.yaml
ALLOW_OPTIONAL_CORPUS=false
CORPUS_STRICT_HASH=true
PDF_MAX_UPLOAD_BYTES=83886080
ALLOWED_SITE_DOMAINS=docs.aws.amazon.com,aws.amazon.com
JOB_TTL_SECONDS=86400
