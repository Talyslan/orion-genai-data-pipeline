# Variáveis para o serviço pipeline no Docker Compose.
# Copie para .env ou use o bloco environment em docker-compose.yml.
#
# Host (dev local): .env.example com localhost
# Container: hostnames internos minio / postgres / qdrant

MINIO_URL=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bronze
MINIO_SECURE=false

POSTGRES_URL=postgresql://orion:orion@postgres:5432/orion
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=document_embeddings

DATA_SOURCE_DIR=/app/pdfs
DATA_SOURCE_EXTENSIONS=.txt,.md,.pdf
LOCAL_OUTPUT_DIR=/app/data/local

PDF_EXTRACTOR=pymupdf
PDF_EXTRACTION_MODE=structured
PDF_OCR_ENABLED=true
PDF_MANIFEST_PATH=/app/pdfs/manifest.yaml
PDF_DOWNLOAD_DIR=/app/pdfs

EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16

TESSERACT_CMD=/usr/bin/tesseract
HF_HOME=/app/.cache/huggingface
TRANSFORMERS_CACHE=/app/.cache/huggingface

# API HTTP
PIPELINE_API_URL=http://pipeline-api:8000/api
SITE_MANIFEST_PATH=/app/sites/manifest.yaml
